{
  "name": "@bolt-socket/core",
  "version": "1.0.0",
  "description": "Type-safe event registry with Zod validation for real-time WebSocket apps",
  "license": "MIT",
  "author": "BoltSocket Contributors",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chakriswamireddy/Boltsocket.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/chakriswamireddy/Boltsocket#readme",
  "bugs": {
    "url": "https://github.com/chakriswamireddy/Boltsocket/issues"
  },
  "keywords": [
    "websocket",
    "socket.io",
    "events",
    "typescript",
    "type-safe",
    "zod",
    "validation",
    "real-time",
    "event-registry",
    "bolt-socket"
  ],
  "peerDependencies": {
    "zod": ">=3.22.0"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "zod": "^3.22.0"
  }
}
