{
  "name": "@chakri-ch/react",
  "version": "1.0.0",
  "description": "React hooks and provider for type-safe real-time WebSocket events with auto-reconnect and observability",
  "license": "MIT",
  "author": "BoltSocket Contributors",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chakriswamireddy/Boltsocket.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/chakriswamireddy/Boltsocket#readme",
  "bugs": {
    "url": "https://github.com/chakriswamireddy/Boltsocket/issues"
  },
  "keywords": [
    "websocket",
    "socket.io",
    "react",
    "hooks",
    "typescript",
    "type-safe",
    "real-time",
    "reconnect",
    "observability",
    "bolt-socket"
  ],
  "peerDependencies": {
    "@chakri-ch/core": ">=1.0.0",
    "react": ">=18.0.0",
    "socket.io-client": ">=4.6.0"
  },
  "devDependencies": {
    "@chakri-ch/core": "workspace:*",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "socket.io-client": "^4.6.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
