{
  "name": "bolt-socket",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack WebSocket abstraction with type-safe events",
  "workspaces": [
    "packages/*",
    "examples"
  ],
  "scripts": {
    "build": "bun run build:core && bun run build:server && bun run build:react",
    "build:core": "cd packages/core && bun run build",
    "build:server": "cd packages/server && bun run build",
    "build:react": "cd packages/react && bun run build",
    "dev:core": "cd packages/core && bun run dev",
    "dev:server": "cd packages/server && bun run dev",
    "dev:react": "cd packages/react && bun run dev",
    "example:basic": "cd examples && bun run example:basic",
    "example:server": "cd examples && bun run example:server",
    "example:all": "cd examples && bun run example:all"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
