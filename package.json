{
  "name": "bolt-socket",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack type-safe WebSocket abstraction for real-time apps",
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "packages/*",
    "examples"
  ],
  "scripts": {
    "build": "pnpm run build:core && pnpm run build:server && pnpm run build:react",
    "build:core": "pnpm --filter @bolt-socket/core run build",
    "build:server": "pnpm --filter @bolt-socket/server run build",
    "build:react": "pnpm --filter @bolt-socket/react run build",
    "dev:core": "pnpm --filter @bolt-socket/core run dev",
    "dev:server": "pnpm --filter @bolt-socket/server run dev",
    "dev:react": "pnpm --filter @bolt-socket/react run dev",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r exec rm -rf dist",
    "publish:core": "pnpm --filter @bolt-socket/core publish",
    "publish:server": "pnpm --filter @bolt-socket/server publish",
    "publish:react": "pnpm --filter @bolt-socket/react publish",
    "publish:all": "pnpm run build && pnpm run publish:core && pnpm run publish:server && pnpm run publish:react",
    "publish:dry": "pnpm run build && pnpm -r exec -- npm pack --dry-run"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chakriswamireddy/Boltsocket.git"
  }
}
