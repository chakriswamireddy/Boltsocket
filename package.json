{
  "name": "@chakri-ch/boltsocket",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack type-safe WebSocket abstraction for real-time apps",
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "packages/*",
    "examples"
  ],
  "scripts": {
    "build": "pnpm --filter @bolt-socket/boltsocket run build",
    "dev": "pnpm --filter @bolt-socket/boltsocket run dev",
    "typecheck": "pnpm --filter @bolt-socket/boltsocket run typecheck",
    "clean": "pnpm --filter @bolt-socket/boltsocket exec rm -rf dist",
    "publish": "pnpm --filter @bolt-socket/boltsocket publish",
    "publish:dry": "pnpm run build && pnpm --filter @bolt-socket/boltsocket exec -- npm pack --dry-run"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chakriswamireddy/Boltsocket.git"
  }
}
